# deployments/dev/.env.example
#
# Скопируйте в deployments/dev/.env и скорректируйте значения.
# Файл .env подхватывается Makefile через `include`.
# Не коммитьте .env в репозиторий.

# =============================================================================
# NATS (общие для всех сервисов)
# =============================================================================
NATS_HOST=127.0.0.1
NATS_PORT=4222
NATS_USER=
NATS_PASSWORD=

# ВАЖНО: однонодовый dev-NATS требует Replicas=1.
# В production (3-нодовый кластер) это значение не задаётся — дефолт 3.
NATS_KV_REPLICAS=1

# =============================================================================
# Gateway
# =============================================================================
HTTP_ADDR=:8080
# Разрешённые Origin-хосты для CORS (через запятую, без пробелов).
ALLOWED_HOSTS=localhost:5173,localhost:3000
# Жёсткий rate limit применяется к этому URL-префиксу (пусто — отключён).
GATEWAY_AUTH_RATE_PREFIX=/v1/xauth/

# =============================================================================
# xauth
# =============================================================================
AUTH_USERNAME=admin
AUTH_PASSWORD=secret

# HMAC-секреты подписи токенов.
# AUTH_ACCESS_SECRET должен совпадать с ACCESS_SECRET в xhttp/xws (и любом
# сервисе, который проверяет access-токены через middleware.RequireAuth).
AUTH_ACCESS_SECRET=dev-access-secret-replace-in-prod
AUTH_REFRESH_SECRET=dev-refresh-secret-replace-in-prod

AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=168h

COOKIE_DOMAIN=
# ВАЖНО: браузер не отправляет Secure-куки по HTTP.
# В production установите true (только HTTPS).
COOKIE_SECURE=false

# =============================================================================
# xhttp
# =============================================================================
DATABASE_URL=postgres://platform:platform@localhost:5432/platform?sslmode=disable

# Должен совпадать с AUTH_ACCESS_SECRET сервиса xauth.
ACCESS_SECRET=dev-access-secret-replace-in-prod

CACHE_TTL=30s

# =============================================================================
# xws
# =============================================================================
INACTIVITY_TIMEOUT=3m

# =============================================================================
# Общие
# =============================================================================
LOG_LEVEL=debug
