# deployments/envs/dev/dev.vars
#
# Переменные для локального запуска через Nomad (dev-режим).
# Не содержит секретов — только dev-значения.
# Используется скриптом start.sh — не передаётся в prod nomad-файлы напрямую.

# NATS (без авторизации в dev)
nats_user     = ""
nats_password = ""

# Gateway
allowed_hosts            = "localhost:3000,localhost:5173"
gateway_auth_rate_prefix = "/v1/xauth/"
log_level                = "debug"

# xauth
auth_username       = "admin"
auth_password       = "dev-password"
auth_access_secret  = "dev-access-secret"
auth_refresh_secret = "dev-refresh-secret"
cookie_domain       = ""
cookie_secure       = "false"

# xhttp
database_url  = "postgres://platform:platform@localhost:5432/platform?sslmode=disable"
access_secret = "dev-access-secret"
cache_ttl     = "30s"

# xws
inactivity_timeout = "3m"
