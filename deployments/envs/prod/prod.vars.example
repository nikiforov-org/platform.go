# deployments/envs/prod/prod.vars.example
#
# Шаблон переменных для ручного production-деплоя (nomad job run -var-file).
# Скопируйте в prod.vars, заполните реальными значениями.
# Не коммитьте prod.vars в репозиторий.
#
# При автодеплое через GitHub Actions этот файл не используется —
# все переменные передаются из GitHub Secrets (см. ci.yml).
#
# Использование:
#
#   # Платформа (всегда):
#   nomad job run -var-file=deployments/envs/prod/prod.vars deployments/infra/nomad/gateway.nomad
#
#   # Демо-сервисы (опционально, не для прод-продуктов):
#   nomad job run -var-file=deployments/envs/prod/prod.vars deployments/infra/nomad/xauth.nomad
#   nomad job run -var-file=deployments/envs/prod/prod.vars deployments/infra/nomad/xhttp.nomad
#   nomad job run -var-file=deployments/envs/prod/prod.vars deployments/infra/nomad/xws.nomad

# GitHub Release (откуда Nomad скачивает бинарники)
github_repo = ""        # owner/repo, например: myorg/platform.go
version     = ""        # тег релиза, например: v1.2.3 или build-42
arch        = "amd64"   # amd64 или arm64

# NATS
nats_user     = ""
nats_password = ""

# Gateway
allowed_hosts            = ""                # например: "example.com,api.example.com"
gateway_auth_rate_prefix = "/v1/xauth/"
gateway_trusted_proxy    = ""                # IP Cloudflare/LB; пустой — X-Real-IP игнорируется
log_level                = "info"

# xauth
auth_username       = ""
auth_password       = ""
auth_access_secret  = ""       # openssl rand -hex 32
auth_refresh_secret = ""       # openssl rand -hex 32
auth_access_ttl     = "15m"    # default из xauth.nomad
auth_refresh_ttl    = "168h"   # default из xauth.nomad
cookie_domain       = ""       # например: ".example.com"
cookie_secure       = "true"

# xhttp
database_url  = ""      # postgres://user:password@host:5432/db?sslmode=require
access_secret = ""      # должен совпадать с auth_access_secret
cache_ttl     = "30s"   # default из xhttp.nomad

# xws
inactivity_timeout = "3m"   # default из xws.nomad
